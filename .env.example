# MeterHub Development Configuration Template
# Copy to .env and customize for your environment

# Environment
METERHUB_ENV=development
METERHUB_DEBUG=true

# Logging
METERHUB_LOG_LEVEL=debug
METERHUB_LOG_FORMAT=json

# Database
METERHUB_DB_PATH=/tmp/meterhub-dev.sqlite

# MQTT (for uploader testing)
METERHUB_MQTT_BROKER=tcp://localhost:1883
METERHUB_MQTT_PORT=1883
METERHUB_MQTT_TLS=false

# HTTPS Fallback (for uploader testing)
METERHUB_HTTPS_FALLBACK=http://localhost:8080
METERHUB_HTTPS_TIMEOUT=30

# Device Configuration
METERHUB_DEVICE_ID=dev-test-device-001
METERHUB_SOCIETY_ID=test-society
METERHUB_PANEL_ID=test-panel-01

# Meter Configuration
METERHUB_METER_ADDRESS=127.0.0.1:5020
METERHUB_METER_PROFILE=schneider-em6400
METERHUB_POLLING_INTERVAL_SECONDS=60

# Installer UI
METREHUB_UI_HOST=0.0.0.0
METERHUB_UI_PORT=8080
METERHUB_UI_HTTPS=false

# Commissioning
METREHUB_INSTALLER_USERNAME=installer
METERHUB_INSTALLER_PASSWORD=changeme

# Fallback Email (for testing)
METERHUB_FALLBACK_EMAIL_ENABLED=false
METERHUB_ADMIN_EMAIL=test@example.com

# Cloud Configuration (for testing with stubs)
METERHUB_CLOUD_ENDPOINT=http://localhost:9000
METERHUB_CLOUD_TOKEN=test-token-123

# AWS SES (if using AWS for fallback email)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
