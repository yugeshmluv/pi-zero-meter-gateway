# Bandit security configuration for MeterHub

[bandit]
# Test IDs to skip
skips = B101,B601  # skip_assert_used, skip_paramiko_calls

# Test IDs to run (explicit list)
tests = B201,B301,B302,B303,B304,B305,B306,B307,B308,B309,B310,B311,B312,B313,B314,B315,B316,B317,B318,B319,B320,B321,B322,B323,B324,B325,B401,B402,B403,B404,B405,B406,B407,B408,B409,B410,B411,B501,B502,B503,B504,B505,B506,B507,B601,B602,B603,B604,B605,B606,B607,B608,B609,B610,B611,B612,B613,B614,B615,B701,B702,B703,B704,B705,B706,B707,B708,B709,B801,B802,B803,B804,B805,B806,B807,B808,B809,B810

# Exclude patterns
exclude_dirs = venv,__pycache__,.git,.pytest_cache

# Assert used - enabled only for test files
assert_used = B101
